# Copy to .env and fill in real keys.

# Gemini (executor — runs the candidate prompts on the selfies).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (agent — the grader + prompt engineer, model gpt-4o in config.yaml).
# This is the GPT-4o / "ChatGPT-4o" key, but it comes from the OpenAI *API*
# (platform.openai.com/api-keys, starts with sk-), NOT from ChatGPT the app.
# A ChatGPT Plus subscription does NOT provide this — you need a funded OpenAI
# API account. Put that same key here.
OPENAI_API_KEY=
